Bootstrap: docker
From: pytorch/pytorch:2.11.0-cuda13.0-cudnn9-devel

%files
    boltz         /opt/conforflux/boltz
    conforflux    /opt/conforflux/conforflux
    examples      /opt/conforflux/examples
    assets        /opt/conforflux/assets
    pyproject.toml /opt/conforflux/pyproject.toml
    README.md      /opt/conforflux/README.md
    LICENSE        /opt/conforflux/LICENSE

%post
    apt-get update && apt-get install -y --no-install-recommends \
        git wget curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

    export PIP_BREAK_SYSTEM_PACKAGES=1
    cd /opt/conforflux
    pip install --no-cache-dir -e ./boltz
    pip install --no-cache-dir \
        "cuequivariance-ops-torch-cu12==0.9.1" \
        "cuequivariance-torch==0.9.1" \
        "cuequivariance-ops-cu12==0.9.1"
    pip install --no-cache-dir -e .

%environment
    export HOME=/tmp
    export NUMBA_CACHE_DIR=/tmp

%runscript
    exec conforflux "$@"

%labels
    Maintainer Shosuke Suzuki
